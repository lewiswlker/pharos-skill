# ── Pharos testnet config (public, safe to commit) ──
PHAROS_RPC_URL=https://atlantic.dplabs-internal.com
PHAROS_CHAIN_ID=688689
PHAROS_EXPLORER=https://atlantic.pharosscan.xyz

# ── Secrets: put real values only in .env (git-ignored). NEVER commit. ──
# WARNING: use a TESTNET-ONLY wallet. Never a key holding real funds.
PRIVATE_KEY=
# Optional separate relayer that submits settlements (gasless for the payer).
# Defaults to PRIVATE_KEY when empty.
RELAYER_PRIVATE_KEY=

# ── Filled in automatically by scripts/deploy.py ──
TUSD_ADDRESS=
LEDGER_ADDRESS=
PAY_TO_ADDRESS=

# ── Local service endpoints ──
FACILITATOR_URL=http://127.0.0.1:8401
SERVER_URL=http://127.0.0.1:8402

# ── Pricing and budget guardrails (human units of TUSD) ──
RESOURCE_PRICE=0.10
BUDGET_PER_CALL=0.50
BUDGET_TOTAL=5.00
